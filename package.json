{
  "name": "@stone-js/router",
  "version": "0.0.1",
  "description": "Stone.js router",
  "author": "Mr. Stone <pierre.evens16@gmail.com>",
  "license": "MIT",
  "repository": "git@github.com:stonemjs/router.git",
  "homepage": "https://github.com/stonemjs/router#readme",
  "bugs": {
    "url": "https://github.com/stonemjs/router/issues"
  },
  "keywords": [
    "node",
    "worker",
    "browser",
    "Stone.js",
    "router",
    "serverless"
  ],
  "main": "./src/index.mjs",
  "module": "./src/index.mjs",
  "types": "./types/index.d.mts",
  "typings": "./types/index.d.mts",
  "files": [
    "/src",
    "/dist",
    "/types"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./types/index.d.mts",
        "default": "./src/index.mjs"
      },
      "require": {
        "types": "./types/index.d.mts",
        "default": "./test/index.js"
      }
    }
  },
  "scripts": {
    "types": "tsc",
    "lint": "standard src",
    "lint:fix": "standard --fix src tests",
    "lint:test": "standard --env jest tests",
    "predoc": "rimraf docs",
    "doc": "jsdoc src/index.mjs -d docs",
    "build": "npm run lint && rollup -c && npm run types",
    "build:dev": "cross-env NODE_ENV=dev npm run build",
    "release": "npm run test:text && npm run build && npm publish --access public",
    "test": "npm run lint:test && jest",
    "test:cvg": "npm run lint:test && jest --coverage",
    "test:text": "npm run test:cvg -- --coverageReporters=text",
    "test:html": "npm run test:cvg -- --coverageReporters=html text",
    "test:lcov": "npm run test:cvg -- --coverageReporters=lcov text"
  },
  "dependencies": {
    "@stone-js/pipeline": "^1.0.1",
    "deepmerge": "^4.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.22.20",
    "@babel/eslint-parser": "^7.22.15",
    "@babel/preset-env": "^7.22.20",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.2",
    "rimraf": "^5.0.5",
    "rollup": "^4.1.5",
    "rollup-plugin-delete": "^2.0.0",
    "rollup-plugin-node-externals": "^6.1.2",
    "standard": "^17.1.0",
    "typescript": "^5.2.2"
  },
  "standard": {
    "parser": "@babel/eslint-parser",
    "globals": [
      "it",
      "jest",
      "test",
      "expect",
      "describe",
      "beforeEach"
    ]
  }
}
