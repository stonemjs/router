{
  "roots": ["src/", "tests/"],
  "transform": {
    "\\.m?[jt]sx?$": ["babel-jest", {
      "presets": [
        ["@babel/env", {
          "modules": "commonjs"
        }]
      ]
    }]
  },
  "collectCoverageFrom": [
    "src/**/*.{js,mjs}",
    "!src/index.mjs"
  ],
  "coverageThreshold": {
    "global": {
      "lines": 80,
      "branches": 80,
      "functions": 80
    }
  },
  "testEnvironment": "node",
  "transformIgnorePatterns": [
    "node_modules/(?!(\\@stone-js)/)"
  ]
}